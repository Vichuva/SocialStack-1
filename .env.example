# ─── Application ───────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | production | test
LOG_LEVEL=INFO
LOG_FORMAT=text                  # text | json (use json in production)

# ─── Database (Supabase PostgreSQL via PgBouncer) ──────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ─── Supabase ──────────────────────────────────────────────────────────────
# All 4 values are in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=eyJh...          # "anon / public" key
SUPABASE_SERVICE_ROLE_KEY=eyJh...  # "service_role" key  ← keep secret
SUPABASE_JWT_SECRET=...            # Settings → API → JWT Settings → JWT Secret

# ─── Redis / Celery ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_SOFT_TIME_LIMIT=600
CELERY_TASK_TIME_LIMIT=900

# ─── AI — text (Google Gemini or OpenAI) ────────────────────────────────────
# Spec uses Google Gemini for captions/themes + Imagen for images — one GOOGLE_API_KEY covers both
GOOGLE_API_KEY=AIza...     # console.cloud.google.com → Credentials → Create API key
                            # Enable: Generative Language API + Vertex AI API

# OpenAI (optional — used if OPENAI_API_KEY is set and google key is absent)
AI_CHAT_MODEL=gpt-4o-mini
AI_MAX_RETRIES=3
OPENAI_API_KEY=sk-proj-...

# ─── AI — image (Google Imagen 3) ────────────────────────────────────────────
AI_IMAGE_MODEL=imagen-3.0-generate-002

# ─── Storage ─────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local            # local | s3 | supabase
LOCAL_STORAGE_PATH=./data/media
LOCAL_STORAGE_BASE_URL=http://localhost:8000/media

# S3 (when STORAGE_BACKEND=s3)
S3_BUCKET=socialstack-media
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Security ─────────────────────────────────────────────────────────────────
# API secret key for internal admin endpoints (keep different from BACKEND_API_KEY)
API_SECRET_KEY=change-me-in-production    # python -c "import secrets; print(secrets.token_urlsafe(64))"

# Bearer token for n8n / agent-to-agent calls (no user JWT)
BACKEND_API_KEY=                           # python -c "import secrets; print(secrets.token_urlsafe(32))"

# Fernet key for encrypting stored OAuth tokens
TOKEN_ENCRYPTION_KEY=                      # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# HMAC secret for verifying inbound social webhooks (Meta calls this endpoint)
SOCIAL_WEBHOOK_SECRET=                     # python -c "import secrets; print(secrets.token_urlsafe(32))"
INBOUND_HMAC_SECRET=                       # alias — either one works

# ─── CORS ────────────────────────────────────────────────────────────────────
FRONTEND_URL=*                             # set to https://app.welvom.com in production

# ─── CRON schedule ───────────────────────────────────────────────────────────
PUBLISH_CRON_EVERY_MINUTES=5
METRICS_CRON_EVERY_HOURS=6

# ─── Concurrency limits ───────────────────────────────────────────────────────
MAX_CONCURRENT_IMAGE_TASKS=5
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ─── Observability ────────────────────────────────────────────────────────────
SENTRY_DSN=                                # https://<key>@sentry.io/<project-id>
SLACK_WEBHOOK_URL=                         # ops alerts (publish failures, AI errors)
NOTIFICATION_WEBHOOK_URL=                  # outbound webhook for client events
