# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_FORMAT=text

# Database
DATABASE_URL=postgresql+asyncpg://socialstack:password@postgres:5432/socialstack

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_SOFT_TIME_LIMIT=600
CELERY_TASK_TIME_LIMIT=900

# AI — text (OpenAI)
AI_CHAT_MODEL=gpt-4o-mini
AI_MAX_RETRIES=3
OPENAI_API_KEY=sk-...

# AI — image (Google)
AI_IMAGE_MODEL=nano-banana-pro
GOOGLE_API_KEY=...

# Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./data/media
LOCAL_STORAGE_BASE_URL=http://localhost:8000/media
# S3 (when STORAGE_BACKEND=s3)
S3_BUCKET=socialstack-media
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Supabase storage (when STORAGE_BACKEND=supabase)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Security
API_SECRET_KEY=change-me-in-production
TOKEN_ENCRYPTION_KEY=   # generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
INBOUND_HMAC_SECRET=

# CRON schedule
PUBLISH_CRON_EVERY_MINUTES=5
METRICS_CRON_EVERY_HOURS=6

# Concurrency limits
MAX_CONCURRENT_IMAGE_TASKS=5
RATE_LIMIT_REQUESTS_PER_MINUTE=60
