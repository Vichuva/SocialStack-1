    },
    {
      "parameters": {
        "jsCode": "// Pull the API-shaped sources (by node name) plus the trigger payload\nconst prefs = $('Get Preferences').first().json.data;\nconst business = $('Get Business').first().json.data;\nconst wh = $('Webhook').first().json.body;\nconst day = wh.day;\n\n// Flatten into the exact fields the prompt needs\nreturn [{\n  json: {\n    // identifiers carried downstream\n    slot_id: wh.slot_id,\n    business_id: wh.business_id,\n    // business context\n    business_name: business.name,\n    industry: business.industry,\n    brand_tone: prefs.brand_tone,\n    pain_points: (prefs.pain_points || []).join(', '),\n    // the single day this brief is for\n    date: day.date,\n    theme: day.theme,\n    objective: day.objective,\n    post_idea: day.post_idea\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        -120
      ],
      "id": "f1a00006-0000-4000-8000-000000000006",
      "name": "Merge Context"
    },
    {
      "parameters": {
        "mode": "raw",
        "jsonOutput": "={\n  \"prompt\": \"You are a senior creative director for a {{ $json.industry }} business named {{ $json.business_name }}.\\n\\nBrand tone: {{ $json.brand_tone }}\\nAudience pain points: {{ $json.pain_points }}\\n\\nCreate a creative brief for ONE social media post:\\nTheme: {{ $json.theme }}\\nObjective: {{ $json.objective }}\\nPost idea: {{ $json.post_idea }}\\n\\nReturn ONLY a valid JSON object with these exact fields: hook (a scroll-stopping opening line), key_message (the single core point, one sentence), emotional_angle (the feeling to evoke in the reader), visual_direction (what the image or video should show), cta (a clear call to action). Return ONLY the JSON object. No explanation. No markdown.\"\n}\n",
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        640,
        -120
      ],
      "id": "f1a00007-0000-4000-8000-000000000007",
      "name": "Build AI Prompt"
    },
    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "gpt-4o-mini",
          "mode": "list",
          "cachedResultName": "GPT-4O-MINI"
        },
        "responses": {
          "values": [
            {
              "content": "={{ $json.prompt }}"
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 2.1,
      "position": [
        840,
        -120
      ],
      "id": "f1a00008-0000-4000-8000-000000000008",
      "name": "Message a model",
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000,
      "credentials": {
        "openAiApi": {
          "id": "orXohfwTWr21X9Db",
          "name": "OpenAI - SuperOne"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Trigger payload + context (referenced by name)\nconst wh = $('Webhook').first().json.body;\nconst ctx = $('Merge Context').first().json;\n\n// Grab the raw text GPT returned (OpenAI Responses API structure)\nlet raw;\ntry {\n  raw = $input.first().json.output[0].content[0].text;\n} catch (e) {\n  throw new Error('Could not find AI response text — OpenAI output structure was unexpected.');\n}\n\n// Strip markdown fences if GPT adds them\nconst cleaned = (raw || '').replace(/```json/gi, '').replace(/```/g, '').trim();\n\n// Parse JSON — fail clearly if GPT returned garbage\nlet brief;\ntry {\n  brief = JSON.parse(cleaned);\n} catch (e) {\n  throw new Error('AI did not return valid JSON. Raw start: ' + cleaned.slice(0, 200));\n}\n\n// Validate the brief has all required fields\nconst required = ['hook', 'key_message', 'emotional_angle', 'visual_direction', 'cta'];\nfor (const f of required) {\n  if (!brief[f]) throw new Error('Brief is missing required field: ' + f);\n}\n\n// One item: the brief plus identifiers for the save step\nreturn [{\n  json: {\n    slot_id: wh.slot_id,\n    business_id: wh.business_id,\n    date: ctx.date,\n    theme: ctx.theme,\n    objective: ctx.objective,\n    brief: brief\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1040,
        -120
      ],
      "id": "f1a00009-0000-4000-8000-000000000009",
      "name": "Parse Brief"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "a0000001-0000-4000-8000-000000000001",
              "name": "saved",
              "value": true,
              "type": "boolean"
            },
            {
              "id": "a0000002-0000-4000-8000-000000000002",
              "name": "saved_at",
              "value": "={{ $now.toISO() }}",
              "type": "string"
            }
